{
  "manifest_version": 3,
  "name": "DeepL Translate",
  "version": "1.0.0",
  "description": "選択したテキストをDeepLで翻訳します",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "DeepL Translate"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["contextMenus", "storage", "activeTab"],
  "host_permissions": ["https://api-free.deepl.com/*", "https://api.deepl.com/*"]
}
